{
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "server/**/*.js", "scripts/**/*.mjs"]
}
